# --- Meta / Instagram Graph API ---
# Long-lived Page access token for the Facebook Page linked to your
# Instagram Business/Creator account (used for Business Discovery lookups).
META_ACCESS_TOKEN=your_long_lived_page_access_token
# The Instagram Business Account ID that will act as the "querying" account.
META_IG_USER_ID=1234567890
META_GRAPH_API_VERSION=v19.0

# --- Website scraping (optional) ---
# Comma-separated list of proxies, e.g. http://user:pass@host:port,http://host2:port2
WEBSITE_PROXIES=

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
